{
  "name": "sqlkit",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "tauri": "tauri",
    "lint": "eslint --cache .",
    "lint:fix": "eslint --cache --fix",
    "test": "jest --runInBand --coverage --coverageReporters json-summary text html lcov",
    "test:ci": "jest --runInBand --ci --coverage --coverageReporters json-summary text html lcov"
  },
  "dependencies": {
    "@monaco-editor/loader": "^1.7.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@vueuse/core": "^14.1.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "radix-vue": "^1.9.17",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.0.1",
    "@tauri-apps/cli": "^2",
    "@types/jest": "^30.0.0",
    "@unocss/eslint-plugin": "^66.6.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.39.2",
    "eslint-plugin-format": "^1.3.1",
    "jest": "^30.2.0",
    "lint-staged": "^16.2.7",
    "simple-git-hooks": "^2.13.1",
    "ts-jest": "^29.4.6",
    "typescript": "~5.6.2",
    "unocss": "^66.6.0",
    "unocss-preset-shadcn": "^1.0.1",
    "vite": "^6.0.3",
    "vue-tsc": "^2.1.10"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*.{js,ts,tsx,vue,md,json}": [
      "eslint --cache --fix"
    ]
