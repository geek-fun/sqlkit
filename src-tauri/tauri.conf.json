{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SqlKit",
  "version": "../package.json",
  "identifier": "club.geekfun.sqlkit",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1521",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SqlKit",
        "width": 1600,
        "height": 1000,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": {
          "x": 16,
          "y": 16
        },
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "exceptionDomain": "",
      "signingIdentity": "Developer ID Application: Lisheng Zi",
      "providerShortName": null,
      "entitlements": null,
      "infoPlist": "Info.plist"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["sqlkit"]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBNjI0Qzg3RDA1NDkxMkUKUldRdWtWVFFoMHhpT2dnTkdLcTFpV1Bzc0xqT053TEphclRwQnRTNE01RU45bUFodFI4R2FyaE0K",
      "endpoints": [
        "https://github.com/geek-fun/sqlkit/releases/latest/download/latest.json"
      ]
    }
  }
}
